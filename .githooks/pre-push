#!/bin/bash
# pre-push hook: lint + 통합 테스트 실행
# 통합 테스트 건너뛰기: SKIP_TEST=1 git push

echo "🔍 pre-push: lint 실행 중..."

if ! ./lint.sh; then
  echo "❌ lint 실패 — push 차단"
  exit 1
fi

# ─── 자동 버전 bump ───
# 코드 변경이 있는데 version이 안 바뀌었으면 자동 bump + 커밋
REMOTE_VERSION=$(git show origin/main:.claude-plugin/plugin.json 2>/dev/null | grep '"version"' | sed 's/.*"\([0-9.]*\)".*/\1/')
LOCAL_VERSION=$(grep '"version"' .claude-plugin/plugin.json | sed 's/.*"\([0-9.]*\)".*/\1/')

if [ -n "$REMOTE_VERSION" ] && [ "$REMOTE_VERSION" = "$LOCAL_VERSION" ]; then
  CODE_CHANGES=$(git diff origin/main --name-only -- skills/ commands/ hooks/ test.sh lint.sh 2>/dev/null | head -1)
  if [ -n "$CODE_CHANGES" ]; then
    # conventional commit 분석: feat: → minor, 나머지 → patch
    HAS_FEAT=$(git log origin/main..HEAD --oneline | grep -iE "^[a-f0-9]+ feat[:(]" | head -1)

    IFS='.' read -r MAJOR MINOR PATCH <<< "$LOCAL_VERSION"

    if [ -n "$HAS_FEAT" ]; then
      MINOR=$((MINOR + 1))
      PATCH=0
    else
      PATCH=$((PATCH + 1))
    fi

    NEW_VERSION="$MAJOR.$MINOR.$PATCH"

    # plugin.json + package.json 자동 수정
    sed -i '' "s/\"version\": \"$LOCAL_VERSION\"/\"version\": \"$NEW_VERSION\"/" .claude-plugin/plugin.json
    sed -i '' "s/\"version\": \"$LOCAL_VERSION\"/\"version\": \"$NEW_VERSION\"/" package.json

    # 자동 커밋
    git add .claude-plugin/plugin.json package.json
    git commit -m "chore: bump version to $NEW_VERSION"

    echo ""
    echo "📦 버전 자동 업데이트: $LOCAL_VERSION → $NEW_VERSION"
    echo "   새 커밋이 추가됐으므로 다시 push해주세요: git push"
    echo ""
    exit 1
  fi
fi

if [ "${SKIP_TEST:-0}" = "1" ]; then
  echo "⏭️  SKIP_TEST=1 — 통합 테스트 건너뜀"
  exit 0
fi

echo ""
echo "🔬 pre-push: 통합 테스트 실행 중... (건너뛰려면 SKIP_TEST=1 git push)"
echo ""

if ! ./test.sh; then
  echo "❌ 통합 테스트 실패 — push 차단. ./test.sh 로 확인하세요."
  exit 1
fi

echo "✅ 전체 테스트 통과 — push 진행"
